#!/bin/sh
# Block Cursor co-author trailers and em dash in commit messages.

msg_file="$1"

if grep -qiE '^[Cc]o-[Aa]uthored-[Bb]y:.*([Cc]ursor|cursoragent@cursor\.com)' "$msg_file"; then
  echo "commit-msg: blocked Cursor co-author trailer in commit message."
  exit 1
fi

if grep -viE '^#' "$msg_file" | grep -qiE '\bmade with cursor\b|\bcomposed by cursor\b'; then
  echo "commit-msg: blocked Cursor-related text in commit message."
  exit 1
fi

if grep -q $'\342\200\224' "$msg_file"; then
  echo "commit-msg: blocked em dash in commit message. Use hyphen instead."
  exit 1
fi

exit 0
